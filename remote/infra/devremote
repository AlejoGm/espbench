#!/bin/bash
set -euo pipefail

# Siempre correr como sfypi — es el usuario dueño del tmux server y los procesos.
# Así devremote funciona igual desde systemd, SSH como sensipi, o cualquier usuario.
if [ "$(whoami)" != "sfypi" ]; then
  exec sudo -u sfypi "$0" "$@"
fi

BASE_PORT=5000
PREFIX="esp32_"

usage() {
  echo "Usage: devremote [--reset [N]|--status|--unlock <N>|--cleanup [--dry-run] [--jobs-days N] [--logs-days N]|<N>]"
  exit 1
}

list_devs() {
  ls -1 /dev/ttyUSB* 2>/dev/null || true
}

session_name_for_dev() {
  local dev="$1"
  echo "${PREFIX}$(basename "$dev")"
}

port_for_dev() {
  local dev="$1"
  local name num
  name="$(basename "$dev")"      # ttyUSBX
  num="${name#ttyUSB}"           # X
  echo $((BASE_PORT + num))
}

start_one() {
  local dev="$1"
  local sess
  sess="$(session_name_for_dev "$dev")"

  if tmux has-session -t "$sess" 2>/dev/null; then
    return 0
  fi

  /usr/local/bin/esp32_tmux.sh "$dev"
}

scan_start_missing() {
  local dev
  while read -r dev; do
    [ -e "$dev" ] || continue
    start_one "$dev"
  done < <(list_devs)
}

reset_all() {
  # Patrón "python3.*remote_esp32[.]py" evita matar el tmux server (cuyo cmdline
  # también contiene "remote_esp32.py") y evita que pkill se mate a sí mismo.
  sudo pkill -9 -f "python3.*remote_esp32[.]py" 2>/dev/null || true
  sleep 1

  tmux ls 2>/dev/null | awk -F: '{print $1}' | grep "^${PREFIX}" | while read -r s; do
    tmux kill-session -t "$s" || true
  done

  scan_start_missing
}

reset_one() {
  local num="$1"
  local dev="/dev/ttyUSB${num}"
  local sess
  sess="$(session_name_for_dev "$dev")"

  sudo pkill -9 -f "python3.*remote_esp32[.]py.*ttyUSB${num}" 2>/dev/null || true
  sleep 1

  tmux kill-session -t "$sess" 2>/dev/null || true

  if [ ! -e "$dev" ]; then
    echo "Advertencia: $dev no existe, sesión no reiniciada" >&2
    return
  fi

  start_one "$dev"
}

status() {
  local dev sess port state pid
  while read -r dev; do
    [ -e "$dev" ] || continue

    sess="$(session_name_for_dev "$dev")"
    port="$(port_for_dev "$dev")"

    if tmux has-session -t "$sess" 2>/dev/null; then
      pid="$(tmux list-panes -t "$sess" -F "#{pane_pid}" 2>/dev/null | head -n1 || true)"
      state="RUNNING"
    else
      pid="-"
      state="DOWN"
    fi

    printf "%-12s  %-16s  tcp=%-5s  %-7s  pid=%s\n" "$(basename "$dev")" "$sess" "$port" "$state" "$pid"
  done < <(list_devs)
}

attach_one() {
  local num="$1"
  local dev="/dev/ttyUSB${num}"
  local sess

  if [ ! -e "$dev" ]; then
    echo "Error: dispositivo $dev no existe" >&2
    exit 1
  fi

  sess="$(session_name_for_dev "$dev")"

  if ! tmux has-session -t "$sess" 2>/dev/null; then
    echo "Error: sesión tmux '$sess' no existe" >&2
    exit 1
  fi

  exec tmux attach-session -t "$sess"
}

unlock_one() {
  local dev="/dev/ttyUSB${1}"
  local name
  name="$(basename "$dev")"
  local lock_file="/opt/esp/locks/$name"
  if [ -f "$lock_file" ]; then
    local user
    user="$(cat "$lock_file")"
    rm -f "$lock_file"
    echo "Lock liberado (era de: $user) → $name"
  else
    echo "No había lock en $name"
  fi
}

cleanup() {
  local dry_run=0
  local jobs_days=7
  local logs_days=30
  local base="/opt/esp"

  shift  # consumir "--cleanup"
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --dry-run)    dry_run=1 ;;
      --jobs-days)  jobs_days="${2:?--jobs-days requiere valor}"; shift ;;
      --logs-days)  logs_days="${2:?--logs-days requiere valor}"; shift ;;
      *) echo "Opción desconocida: $1" >&2; exit 1 ;;
    esac
    shift
  done

  local removed_jobs=0 removed_days=0 freed=0

  echo "=== devremote cleanup ==="
  [ "$dry_run" = "1" ] && echo "(dry-run: no se borra nada)"
  echo "  jobs > ${jobs_days}d  →  ${base}/jobs/"
  echo "  logs > ${logs_days}d  →  ${base}/logs/YYYYMMDD/"
  echo ""

  # Jobs dirs
  if [ -d "${base}/jobs" ]; then
    while IFS= read -r -d '' jobdir; do
      local size
      size=$(du -sh "$jobdir" 2>/dev/null | cut -f1)
      echo "  [job] $jobdir  ($size)"
      if [ "$dry_run" = "0" ]; then
        rm -rf "$jobdir"
      fi
      removed_jobs=$((removed_jobs + 1))
    done < <(find "${base}/jobs" -mindepth 1 -maxdepth 1 -type d -mtime "+${jobs_days}" -print0)
  fi

  # Log day dirs
  if [ -d "${base}/logs" ]; then
    while IFS= read -r -d '' daydir; do
      local size
      size=$(du -sh "$daydir" 2>/dev/null | cut -f1)
      echo "  [log] $daydir  ($size)"
      if [ "$dry_run" = "0" ]; then
        rm -rf "$daydir"
      fi
      removed_days=$((removed_days + 1))
    done < <(find "${base}/logs" -mindepth 2 -maxdepth 2 -type d -mtime "+${logs_days}" -print0)
  fi

  echo ""
  if [ "$dry_run" = "1" ]; then
    echo "Encontrados: ${removed_jobs} job dir(s), ${removed_days} log day dir(s) para borrar"
  else
    echo "Borrados: ${removed_jobs} job dir(s), ${removed_days} log day dir(s)"
  fi
}

if [ "${1:-}" = "--reset" ]; then
  if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
    reset_one "$2"
  else
    reset_all
  fi
  exit 0
elif [ "${1:-}" = "--status" ]; then
  status
  exit 0
elif [ "${1:-}" = "--unlock" ]; then
  if [ -z "${2:-}" ]; then
    echo "Uso: devremote --unlock <número>" >&2; exit 1
  fi
  unlock_one "$2"
  exit 0
elif [ "${1:-}" = "--cleanup" ]; then
  cleanup "$@"
  exit 0
elif [ -z "${1:-}" ]; then
  scan_start_missing
  exit 0
elif [[ "$1" =~ ^[0-9]+$ ]]; then
  attach_one "$1"
  exit 0
else
  usage
fi
