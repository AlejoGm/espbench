#!/bin/bash
set -euo pipefail

# Siempre correr como sfypi — es el usuario dueño del tmux server y los procesos.
# Así devremote funciona igual desde systemd, SSH como sensipi, o cualquier usuario.
if [ "$(whoami)" != "sfypi" ]; then
  exec sudo -u sfypi "$0" "$@"
fi

BASE_PORT=5000
PREFIX="esp32_"

usage() {
  echo "Usage: devremote [--reset [N]|--status|--unlock <N>|<N>]"
  exit 1
}

list_devs() {
  ls -1 /dev/ttyUSB* 2>/dev/null || true
}

session_name_for_dev() {
  local dev="$1"
  echo "${PREFIX}$(basename "$dev")"
}

port_for_dev() {
  local dev="$1"
  local name num
  name="$(basename "$dev")"      # ttyUSBX
  num="${name#ttyUSB}"           # X
  echo $((BASE_PORT + num))
}

start_one() {
  local dev="$1"
  local sess
  sess="$(session_name_for_dev "$dev")"

  if tmux has-session -t "$sess" 2>/dev/null; then
    return 0
  fi

  /usr/local/bin/esp32_tmux.sh "$dev"
}

scan_start_missing() {
  local dev
  while read -r dev; do
    [ -e "$dev" ] || continue
    start_one "$dev"
  done < <(list_devs)
}

reset_all() {
  # Patrón "python3.*remote_esp32[.]py" evita matar el tmux server (cuyo cmdline
  # también contiene "remote_esp32.py") y evita que pkill se mate a sí mismo.
  sudo pkill -9 -f "python3.*remote_esp32[.]py" 2>/dev/null || true
  sleep 1

  tmux ls 2>/dev/null | awk -F: '{print $1}' | grep "^${PREFIX}" | while read -r s; do
    tmux kill-session -t "$s" || true
  done

  scan_start_missing
}

reset_one() {
  local num="$1"
  local dev="/dev/ttyUSB${num}"
  local sess
  sess="$(session_name_for_dev "$dev")"

  sudo pkill -9 -f "python3.*remote_esp32[.]py.*ttyUSB${num}" 2>/dev/null || true
  sleep 1

  tmux kill-session -t "$sess" 2>/dev/null || true

  if [ ! -e "$dev" ]; then
    echo "Advertencia: $dev no existe, sesión no reiniciada" >&2
    return
  fi

  start_one "$dev"
}

status() {
  local dev sess port state pid
  while read -r dev; do
    [ -e "$dev" ] || continue

    sess="$(session_name_for_dev "$dev")"
    port="$(port_for_dev "$dev")"

    if tmux has-session -t "$sess" 2>/dev/null; then
      pid="$(tmux list-panes -t "$sess" -F "#{pane_pid}" 2>/dev/null | head -n1 || true)"
      state="RUNNING"
    else
      pid="-"
      state="DOWN"
    fi

    printf "%-12s  %-16s  tcp=%-5s  %-7s  pid=%s\n" "$(basename "$dev")" "$sess" "$port" "$state" "$pid"
  done < <(list_devs)
}

attach_one() {
  local num="$1"
  local dev="/dev/ttyUSB${num}"
  local sess

  if [ ! -e "$dev" ]; then
    echo "Error: dispositivo $dev no existe" >&2
    exit 1
  fi

  sess="$(session_name_for_dev "$dev")"

  if ! tmux has-session -t "$sess" 2>/dev/null; then
    echo "Error: sesión tmux '$sess' no existe" >&2
    exit 1
  fi

  exec tmux attach-session -t "$sess"
}

unlock_one() {
  local dev="/dev/ttyUSB${1}"
  local name
  name="$(basename "$dev")"
  local lock_file="/opt/esp/locks/$name"
  if [ -f "$lock_file" ]; then
    local user
    user="$(cat "$lock_file")"
    rm -f "$lock_file"
    echo "Lock liberado (era de: $user) → $name"
  else
    echo "No había lock en $name"
  fi
}

if [ "${1:-}" = "--reset" ]; then
  if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
    reset_one "$2"
  else
    reset_all
  fi
  exit 0
elif [ "${1:-}" = "--status" ]; then
  status
  exit 0
elif [ "${1:-}" = "--unlock" ]; then
  if [ -z "${2:-}" ]; then
    echo "Uso: devremote --unlock <número>" >&2; exit 1
  fi
  unlock_one "$2"
  exit 0
elif [ -z "${1:-}" ]; then
  scan_start_missing
  exit 0
elif [[ "$1" =~ ^[0-9]+$ ]]; then
  attach_one "$1"
  exit 0
else
  usage
fi
